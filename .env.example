COMPOSE_PROJECT_NAME=diabetes-risk-app
DATABASE_URL=sqlite+aiosqlite:///./diabetes_app.db
POSTGRES_DB=diabetes_risk
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

MODEL_DATA_URL=https://raw.githubusercontent.com/npradaschnor/Pima-Indians-Diabetes-Dataset/master/diabetes.csv
MODEL_TARGET_COLUMN=Outcome
MODEL_NAME=LogisticRegression

BACKEND_PORT=8005
FRONTEND_PORT=3000

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
BACKEND_BASE_URL=http://127.0.0.1:8005
FRONTEND_URL=http://127.0.0.1:3000

JWT_SECRET_KEY=put-a-long-random-secret-here
SESSION_SECRET_KEY=put-another-long-random-secret-here

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

VITE_API_BASE_URL=/api
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token
ADMIN_EMAILS=
